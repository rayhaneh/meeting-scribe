# Copy to .env and fill in. .env is gitignored.

# Path to the whisper.cpp binary (default: whisper-cli on PATH)
# WHISPER_BIN=whisper-cli

# Path to the ggml model file
WHISPER_MODEL=$HOME/.local/share/whisper/ggml-base.en.bin

# --- Summaries (local LLM via Ollama) ---
# Model used by summarize.sh (default: llama3.1:8b). Pull it with:
#   ollama pull llama3.1:8b
# OLLAMA_MODEL=llama3.1:8b

# --- Notion (used in a later milestone) ---
# NOTION_TOKEN=secret_xxx
# NOTION_PARENT_PAGE_ID=xxxxxxxxxxxx
